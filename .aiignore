# Paths AI agents should not load into context. Generated, vendored, or low-signal.
# Source, contracts, docs, and tests are intentionally NOT listed here.

# Dependencies / vendor
node_modules/

# Build output / caches
.next/
dist/
coverage/
playwright-report/
test-results/
*.tsbuildinfo

# Lockfiles (large, machine-generated)
package-lock.json

# Secrets (never load)
.env
.env*.local

# Agent run logs / loop artifacts (history lives in `git log`)
codex-runs/
docs/loop-artifacts/
LOOP_LOG.md
docs/LOOP_LOG.md
*.log

# Read with targeted `rg`, not wholesale (see docs/ai/REPO_MAP.md)
# tests/unit/auth/api-route-authorization.test.ts
# tests/unit/queue/live-worker-controls.test.ts
# contracts/CONTRACT-TESTING.md
