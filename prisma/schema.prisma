generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum ConsentStatus {
  UNKNOWN
  OPTED_IN
  OPTED_OUT
}

enum ConversationStatus {
  OPEN
  RESOLVED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  PAUSED
  COMPLETED
}

enum ContactImportStatus {
  PENDING
  COMPLETED
  FAILED
}

enum CampaignRecipientStatus {
  PENDING
  BLOCKED
}

enum QueueJobType {
  SCHEDULED_CAMPAIGN
}

enum QueueJobStatus {
  QUEUED
  CANCELLED
  COMPLETED
  FAILED
}

enum A2pRegistrationStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum UsageEventType {
  CONTACT_IMPORTED
  MESSAGE_INBOUND
  CAMPAIGN_SCHEDULED
  AI_REQUEST
}

enum BillingAccountStatus {
  DEMO
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum ProviderPhoneNumberStatus {
  DEMO
  CONFIGURED
  DISABLED
}

model Organization {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  clerkOrgId    String?        @unique
  demoMode      Boolean        @default(true)
  timezone      String         @default("America/Los_Angeles")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  memberships   Membership[]
  contacts      Contact[]
  tags          Tag[]
  contactLists  ContactList[]
  segments      Segment[]
  contactImports ContactImport[]
  templates     MessageTemplate[]
  campaigns     Campaign[]
  queueJobs     QueueJob[]
  conversations Conversation[]
  messages      Message[]
  internalNotes InternalNote[]
  complianceProfile ComplianceProfile?
  usageEvents   UsageEvent[]
  billingAccount BillingAccount?
  webhookEvents WebhookEvent[]
  providerPhoneNumbers ProviderPhoneNumber[]
  liveReadinessAuditEvents LiveReadinessAuditEvent[]
}

model AppUser {
  id          String       @id @default(cuid())
  clerkUserId String       @unique
  email       String       @unique
  displayName String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  assignedConversations Conversation[] @relation("ConversationAssignee")
  internalNotes InternalNote[]
}

model Membership {
  id        String         @id @default(cuid())
  orgId     String
  userId    String
  role      MembershipRole @default(MEMBER)
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  org       Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      AppUser        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

model Contact {
  id            String        @id @default(cuid())
  orgId         String
  phone         String
  email         String?
  firstName     String?
  lastName      String?
  displayName   String?
  consentStatus ConsentStatus @default(UNKNOWN)
  optInSource   String?
  optInAt       DateTime?
  optedOutAt    DateTime?
  source        String?
  notes         String?
  archivedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tagLinks      ContactTag[]
  listLinks     ContactListMember[]
  campaignRecipients CampaignRecipient[]
  conversations Conversation[]
  messages      Message[]

  @@unique([orgId, phone])
  @@index([orgId])
  @@index([orgId, consentStatus])
  @@index([orgId, archivedAt])
}

model Tag {
  id        String       @id @default(cuid())
  orgId     String
  name      String
  color     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contacts  ContactTag[]

  @@unique([orgId, name])
  @@index([orgId])
}

model ContactTag {
  id        String   @id @default(cuid())
  orgId     String
  contactId String
  tagId     String
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([orgId])
  @@index([tagId])
}

model ContactList {
  id          String              @id @default(cuid())
  orgId       String
  name        String
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  org         Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members     ContactListMember[]

  @@unique([orgId, name])
  @@index([orgId])
}

model ContactListMember {
  id        String      @id @default(cuid())
  orgId     String
  listId    String
  contactId String
  createdAt DateTime    @default(now())
  list      ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact   Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
  @@index([orgId])
  @@index([contactId])
}

model Segment {
  id          String       @id @default(cuid())
  orgId       String
  name        String
  description String?
  definition  Json
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
}

model MessageTemplate {
  id          String       @id @default(cuid())
  orgId       String
  name        String
  body        String
  variables   Json
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaigns   Campaign[]

  @@unique([orgId, name])
  @@index([orgId])
}

model ContactImport {
  id           String              @id @default(cuid())
  orgId        String
  filename     String?
  status       ContactImportStatus @default(PENDING)
  totalRows    Int                 @default(0)
  importedRows Int                 @default(0)
  failedRows   Int                 @default(0)
  errors       Json?
  createdAt    DateTime            @default(now())
  completedAt  DateTime?
  org          Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Campaign {
  id          String         @id @default(cuid())
  orgId       String
  templateId  String?
  name        String
  status      CampaignStatus @default(DRAFT)
  body        String
  scheduledAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  org         Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  template    MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recipients  CampaignRecipient[]
  queueJobs   QueueJob[]
  messages    Message[]

  @@index([orgId])
  @@index([orgId, status])
}

model CampaignRecipient {
  id          String                  @id @default(cuid())
  orgId       String
  campaignId  String
  contactId   String
  status      CampaignRecipientStatus @default(PENDING)
  blockReason String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  campaign    Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact     Contact                 @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([orgId])
  @@index([contactId])
}

model Conversation {
  id               String             @id @default(cuid())
  orgId            String
  contactId        String?
  assignedToUserId String?
  status           ConversationStatus @default(OPEN)
  lastMessageAt    DateTime?
  assignedAt       DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  org              Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact          Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo       AppUser?           @relation("ConversationAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  messages         Message[]
  internalNotes    InternalNote[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([contactId])
  @@index([assignedToUserId])
}

model QueueJob {
  id             String         @id @default(cuid())
  orgId          String
  campaignId     String?
  type           QueueJobType
  status         QueueJobStatus @default(QUEUED)
  idempotencyKey String         @unique
  payload        Json
  runAt          DateTime
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  org            Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign       Campaign?      @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, status])
  @@index([campaignId])
}

model Message {
  id                  String        @id @default(cuid())
  orgId               String
  contactId           String?
  conversationId      String?
  campaignId          String?
  direction           String
  body                String
  providerMessageId   String?
  providerStatus      String?
  providerErrorCode   String?
  deliveredAt         DateTime?
  failedAt            DateTime?
  idempotencyKey      String        @unique
  createdAt           DateTime      @default(now())
  org                 Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact             Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation        Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  campaign            Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([conversationId])
  @@index([contactId])
  @@index([providerMessageId])
}

model InternalNote {
  id             String       @id @default(cuid())
  orgId          String
  conversationId String
  authorUserId   String
  body           String
  createdAt      DateTime     @default(now())
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author         AppUser      @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([conversationId])
  @@index([authorUserId])
}

model ComplianceProfile {
  id                 String                @id @default(cuid())
  orgId              String                @unique
  businessName       String?
  messagingUseCase   String?
  optInDescription   String?
  privacyPolicyUrl   String?
  termsOfServiceUrl  String?
  a2pRegistrationStatus A2pRegistrationStatus @default(NOT_STARTED)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  org                Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model UsageEvent {
  id        String         @id @default(cuid())
  orgId     String
  type      UsageEventType
  quantity  Int            @default(1)
  metadata  Json?
  createdAt DateTime       @default(now())
  org       Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, type])
  @@index([createdAt])
}

model BillingAccount {
  id                  String               @id @default(cuid())
  orgId               String               @unique
  status              BillingAccountStatus @default(DEMO)
  liveBillingEnabled  Boolean              @default(false)
  stripeCustomerId    String?
  stripeSubscriptionId String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  org                 Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([status])
}

model ProviderPhoneNumber {
  id           String                    @id @default(cuid())
  orgId        String
  phoneNumber  String
  label        String?
  provider     String                    @default("dummy")
  status       ProviderPhoneNumberStatus @default(DEMO)
  capabilities Json
  isDefault    Boolean                   @default(false)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  org          Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, phoneNumber])
  @@index([orgId])
  @@index([orgId, isDefault])
  @@index([orgId, provider])
}

model LiveReadinessAuditEvent {
  id           String       @id @default(cuid())
  orgId        String
  actorUserId  String?
  action       String
  subjectType  String
  subjectId    String?
  metadata     Json?
  createdAt    DateTime     @default(now())
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, action])
  @@index([createdAt])
}

model WebhookEvent {
  id             String       @id @default(cuid())
  orgId          String
  provider       String
  eventType      String
  idempotencyKey String       @unique
  rawPayload     Json
  receivedAt     DateTime     @default(now())
  processedAt    DateTime?
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, provider, eventType])
  @@index([receivedAt])
}
