generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum ConsentStatus {
  UNKNOWN
  OPTED_IN
  OPTED_OUT
}

enum ConversationStatus {
  OPEN
  RESOLVED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  PAUSED
  COMPLETED
}

enum ContactImportStatus {
  PENDING
  COMPLETED
  FAILED
}

model Organization {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  clerkOrgId    String?        @unique
  demoMode      Boolean        @default(true)
  timezone      String         @default("America/Los_Angeles")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  memberships   Membership[]
  contacts      Contact[]
  tags          Tag[]
  contactLists  ContactList[]
  segments      Segment[]
  contactImports ContactImport[]
  campaigns     Campaign[]
  conversations Conversation[]
  messages      Message[]
}

model AppUser {
  id          String       @id @default(cuid())
  clerkUserId String       @unique
  email       String       @unique
  displayName String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
}

model Membership {
  id        String         @id @default(cuid())
  orgId     String
  userId    String
  role      MembershipRole @default(MEMBER)
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  org       Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      AppUser        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

model Contact {
  id            String        @id @default(cuid())
  orgId         String
  phone         String
  email         String?
  firstName     String?
  lastName      String?
  displayName   String?
  consentStatus ConsentStatus @default(UNKNOWN)
  optInSource   String?
  optInAt       DateTime?
  optedOutAt    DateTime?
  source        String?
  notes         String?
  archivedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tagLinks      ContactTag[]
  listLinks     ContactListMember[]
  messages      Message[]

  @@unique([orgId, phone])
  @@index([orgId])
  @@index([orgId, consentStatus])
  @@index([orgId, archivedAt])
}

model Tag {
  id        String       @id @default(cuid())
  orgId     String
  name      String
  color     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contacts  ContactTag[]

  @@unique([orgId, name])
  @@index([orgId])
}

model ContactTag {
  id        String   @id @default(cuid())
  orgId     String
  contactId String
  tagId     String
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([orgId])
  @@index([tagId])
}

model ContactList {
  id          String              @id @default(cuid())
  orgId       String
  name        String
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  org         Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members     ContactListMember[]

  @@unique([orgId, name])
  @@index([orgId])
}

model ContactListMember {
  id        String      @id @default(cuid())
  orgId     String
  listId    String
  contactId String
  createdAt DateTime    @default(now())
  list      ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact   Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
  @@index([orgId])
  @@index([contactId])
}

model Segment {
  id          String       @id @default(cuid())
  orgId       String
  name        String
  description String?
  definition  Json
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
}

model ContactImport {
  id           String              @id @default(cuid())
  orgId        String
  filename     String?
  status       ContactImportStatus @default(PENDING)
  totalRows    Int                 @default(0)
  importedRows Int                 @default(0)
  failedRows   Int                 @default(0)
  errors       Json?
  createdAt    DateTime            @default(now())
  completedAt  DateTime?
  org          Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Campaign {
  id          String         @id @default(cuid())
  orgId       String
  name        String
  status      CampaignStatus @default(DRAFT)
  body        String
  scheduledAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  org         Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@index([orgId])
}

model Conversation {
  id        String             @id @default(cuid())
  orgId     String
  contactId String?
  status    ConversationStatus @default(OPEN)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  org       Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([orgId])
}

model Message {
  id                  String        @id @default(cuid())
  orgId               String
  contactId           String?
  conversationId      String?
  campaignId          String?
  direction           String
  body                String
  providerMessageId   String?
  idempotencyKey      String        @unique
  createdAt           DateTime      @default(now())
  org                 Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact             Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation        Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  campaign            Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([orgId])
}
